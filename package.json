{
  "name": "mcp-variable",
  "version": "0.1.0",
  "description": "CSV-backed Korean term and physical-name conversion MCP server",
  "type": "module",
  "bin": {
    "mcp-variable": "./dist/server.js",
    "mcp-variable-sse": "./dist/server_sse.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "cache:prebuild": "node scripts/prebuild-cache.mjs",
    "chroma:sync": "node scripts/sync-chroma.mjs",
    "convert:public-standard": "tsx scripts/convert-public-standard-terms.ts",
    "dev": "tsx src/server.ts",
    "dev:sse": "tsx src/server_sse.ts",
    "start": "node dist/server.js",
    "start:sse": "node dist/server_sse.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:presentation": "node scripts/check-beginner-presentation.mjs",
    "check:application-presentation": "node scripts/check-application-presentation.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chromadb": "^3.5.0",
    "csv-parse": "^5.5.6",
    "iconv-lite": "^0.6.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
